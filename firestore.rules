rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(roles) {
      return isSignedIn()
        && request.auth.token.role is string
        && roles.hasAny([request.auth.token.role]);
    }

    function isCrmUser() {
      return hasRole(['admin', 'gestor', 'manager', 'atendente', 'crm']);
    }

    function isStoreMember(storeId) {
      return isSignedIn() && (
        (request.auth.token.lojaId is string && request.auth.token.lojaId == storeId)
        ||
        (request.auth.token.storeId is string && request.auth.token.storeId == storeId)
      );
    }

    function hasStoreField(data) {
      return (data.lojaId is string) || (data.storeId is string);
    }

    function matchesStoreField(data, storeId) {
      return (
        (data.lojaId is string && data.lojaId == storeId)
        ||
        (data.storeId is string && data.storeId == storeId)
      );
    }

    function sameStoreDocument(data) {
      return isSignedIn() && (
        (data.lojaId is string && isStoreMember(data.lojaId))
        ||
        (data.storeId is string && isStoreMember(data.storeId))
      );
    }

    // --- COLEÇÕES GLOBAIS ---
    // Leitura pública para cardápio/loja virtual; escrita somente para CRM autenticado da própria loja.
    match /produtos/{produtoId} {
      allow get, list: if true;
      allow create, update: if isCrmUser() && hasStoreField(request.resource.data) && sameStoreDocument(request.resource.data);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && sameStoreDocument(resource.data);
    }

    match /configuracoes/{docId} {
      allow get, list: if true;
      allow create, update: if isCrmUser() && hasStoreField(request.resource.data) && sameStoreDocument(request.resource.data);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && sameStoreDocument(resource.data);
    }

    match /cupons/{cupomId} {
      allow get, list: if true;
      allow create, update: if isCrmUser() && hasStoreField(request.resource.data) && sameStoreDocument(request.resource.data);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && sameStoreDocument(resource.data);
    }

    // --- FLUXO PÚBLICO MÍNIMO (sem listagem ampla) ---
    match /clientes/{clienteId} {
      // Formulário público pode criar/atualizar cadastro vinculado a uma loja.
      allow create, update: if hasStoreField(request.resource.data);

      // CRM da loja pode consultar clientes; visitantes não podem listar base de clientes.
      allow get, list: if isCrmUser() && sameStoreDocument(resource.data);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && sameStoreDocument(resource.data);
    }

    match /pedidos/{pedidoId} {
      // Checkout público pode criar pedido vinculado a uma loja.
      allow create: if hasStoreField(request.resource.data);

      // CRM da loja opera ciclo do pedido; visitantes não podem listar pedidos.
      allow get, list, update: if isCrmUser() && sameStoreDocument(resource.data);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && sameStoreDocument(resource.data);
    }

    // --- LOJAS / MULTILOJA ---
    match /lojas/{lojaId} {
      allow get: if true;
      allow list: if isCrmUser();
      allow create, update: if isCrmUser() && isStoreMember(lojaId);
      allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);

      match /produtos/{produtoId} {
        allow get, list: if true;
        allow create, update: if isCrmUser() && isStoreMember(lojaId) && matchesStoreField(request.resource.data, lojaId);
        allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);
      }

      match /configuracoes/{docId} {
        allow get, list: if true;
        allow create, update: if isCrmUser() && isStoreMember(lojaId) && matchesStoreField(request.resource.data, lojaId);
        allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);

        match /{subcollection}/{configDocId} {
          allow get, list: if true;
          allow create, update: if isCrmUser() && isStoreMember(lojaId) && matchesStoreField(request.resource.data, lojaId);
          allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);
        }
      }

      match /cupons/{cupomId} {
        allow get, list: if true;
        allow create, update: if isCrmUser() && isStoreMember(lojaId) && matchesStoreField(request.resource.data, lojaId);
        allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);
      }

      match /clientes/{clienteId} {
        allow create, update: if matchesStoreField(request.resource.data, lojaId);
        allow get, list: if isCrmUser() && isStoreMember(lojaId);
        allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);
      }

      match /pedidos/{pedidoId} {
        allow create: if matchesStoreField(request.resource.data, lojaId);
        allow get, list, update: if isCrmUser() && isStoreMember(lojaId);
        allow delete: if isCrmUser() && hasRole(['admin', 'gestor', 'manager']) && isStoreMember(lojaId);
      }
    }
  }
}
